# --- Cloudflare R2 (Phase 2 — pending internal sign-off) ---------------
# Fill these in once the R2 bucket is created and approved. Until then,
# leave them unset and the site automatically serves local placeholder
# images (see src/lib/images.ts / src/lib/r2.ts).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for reading images back out — either the bucket's
# public dev URL (https://pub-xxxx.r2.dev) or a custom domain you attach
# to the bucket (e.g. https://img.vinaayagar.com).
R2_PUBLIC_BASE_URL=

# --- Google Drive sync (Phase 2 — see scripts/sync-drive-to-r2.ts) -----
# Service account JSON credentials for a Google Cloud project with the
# Drive API enabled, shared read access to the synced folder.
GOOGLE_SERVICE_ACCOUNT_JSON=
# The Google Drive folder ID that contains one subfolder per event
# (subfolder names should match album slugs in src/lib/albums.ts).
GOOGLE_DRIVE_ROOT_FOLDER_ID=
