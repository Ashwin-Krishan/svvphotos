# --- Cloudflare R2 -------------------------------------------------------
# Live in production. If left unset (e.g. for local dev without real
# credentials), the site falls back to local placeholder images
# (src/lib/images.ts) and the sync pipeline writes compressed output to
# ./sync/local-output instead of uploading (sync/lib/destination.ts).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for reading images back out — either the bucket's
# public dev URL (https://pub-xxxx.r2.dev) or a custom domain you attach
# to the bucket (e.g. https://img.vinaayagar.com).
R2_PUBLIC_BASE_URL=

# --- Google Drive sync (see sync/lib/sources/driveSource.ts) -----------
# Service account JSON credentials for a Google Cloud project with the
# Drive API enabled, shared (as Viewer) with the inbox folder. Paste the
# full downloaded JSON key on one line, or base64-encode it — both work.
# Only needed for `npm run sync:drive` (the scheduled/Drive path) — the
# local on-demand path (`npm run sync:local`) never touches Drive.
GOOGLE_SERVICE_ACCOUNT_JSON=
# The "Temple Website Photos - Inbox" folder's ID (from its Drive URL).
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- GitHub (for albums.generated.json registration on main) -----------
# Only needed for local runs (sync:drive / sync:local) — GitHub Actions
# already provides this automatically. If you have the GitHub CLI
# installed and `gh auth login`'d, you can leave this blank entirely;
# the pipeline falls back to `gh auth token` automatically.
GITHUB_TOKEN=

# --- On-demand revalidation (sync/lib/revalidate.ts) --------------------
# After every sync, the pipeline calls the deployed site's
# /api/revalidate route so new/changed photos show up immediately
# instead of waiting on ISR's 10-minute window (which only refreshes on
# the next visit after it elapses — a real gap on a low-traffic site).
# Both values must match between here, the Vercel project's env vars,
# and the GitHub Actions secrets — if either is missing, the pipeline
# just logs a note and skips this step; ISR remains the fallback.
PUBLIC_SITE_URL=
REVALIDATE_SECRET=
